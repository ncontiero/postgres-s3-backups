{
  "name": "postgres-s3-backups",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "A simple utility to backup Postgres databases to S3 using Bun.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile postgres-s3-backup",
    "start": "bun run src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@t3-oss/env-core": "0.13.11",
    "colorette": "2.0.20",
    "cron": "4.4.0",
    "filesize": "11.0.17",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.2",
    "@types/bun": "1.3.14",
    "eslint": "10.4.1"
  }
}
